from flask import Flask, render_template_string, request, redirect
import sqlite3

app = Flask(__name__)

# Create Database
def init_db():

    conn = sqlite3.connect("team.db")
    cursor = conn.cursor()

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS team (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT,
            available INTEGER
        )
    """)

    # Insert default users if table is empty
    cursor.execute("SELECT COUNT(*) FROM team")

    count = cursor.fetchone()[0]

    if count == 0:

        users = [
            ("Alice", 1),
            ("Bob", 0),
            ("Charlie", 1),
            ("David", 0)
        ]

        cursor.executemany(
            "INSERT INTO team (name, available) VALUES (?, ?)",
            users
        )

    conn.commit()
    conn.close()

# HTML Page
HTML_PAGE = """

<!DOCTYPE html>
<html>
<head>


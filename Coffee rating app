# Home Page
@app.route("/")
def home():

    conn = sqlite3.connect("coffee.db")
    cursor = conn.cursor()

    cursor.execute("SELECT * FROM coffee")

    coffees = cursor.fetchall()

    conn.close()

    return render_template_string(
        HTML_PAGE,
        coffees=coffees
    )

# Vote Route
@app.route("/vote", methods=["POST"])
def vote():

    coffee_id = request.form["coffee_id"]

    conn = sqlite3.connect("coffee.db")
    cursor = conn.cursor()

    cursor.execute(
        "UPDATE coffee SET votes = votes + 1 WHERE id = ?",
        (coffee_id,)
    )

    conn.commit()
    conn.close()

    return redirect("/")

# Run Application
if __name__ == "__main__":

    init_db()

    app.run(debug=True)
